# Go backend configuration
PORT=8080
LOG_LEVEL=info

# Database (connects to the same Postgres as Rails)
# Check config/database.yml for the actual database name — it may include your OS username.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=fat_free_crm_development
DB_SSLMODE=disable

# Or provide a full connection string (takes precedence over DB_* vars)
# DATABASE_URL=postgres://user:password@localhost:5432/fat_free_crm_development?sslmode=disable
